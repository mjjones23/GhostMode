# Copy this file to backend/.env
# NEVER commit backend/.env or put OPENAI_API_KEY in the mobile app.

# Port for the Ghost Mode backend API (local and hosted)
PORT=3001

# OpenAI — get a key at https://platform.openai.com/api-keys
# This key stays on the server only.
OPENAI_API_KEY=sk-your-openai-key-here

# Optional — defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# For TestFlight/App Store: deploy this backend behind public HTTPS
# (Railway, Render, Fly.io, etc.), set OPENAI_API_KEY on the host,
# then put that HTTPS origin in eas.json as EXPO_PUBLIC_COACH_API_URL.