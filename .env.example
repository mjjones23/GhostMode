# Copy this file to .env in the project root (optional for local Expo).
# This tells the mobile app where your Ghost Mode backend server lives.
# Do NOT put OPENAI_API_KEY here — that stays in backend/.env only.

# --- Local development (phone on same Wi‑Fi as your PC) ---
# 1. Run: npm run backend
# 2. Set your PC's current Wi‑Fi IP (ipconfig → IPv4)
EXPO_PUBLIC_COACH_API_URL=http://10.0.0.200:3001

# iOS Simulator alternative:
# EXPO_PUBLIC_COACH_API_URL=http://localhost:3001

# Android Emulator alternative:
# EXPO_PUBLIC_COACH_API_URL=http://10.0.2.2:3001

# --- Production / TestFlight ---
# Deploy backend/ to a public HTTPS host, then set the same URL in eas.json
# (preview + production env) or as an EAS secret:
# EXPO_PUBLIC_COACH_API_URL=https://your-backend.example.com

# RevenueCat (Apple subscriptions — optional until App Store Connect is ready)
# EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_your_revenuecat_public_key_here
# EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_your_revenuecat_public_key_here
